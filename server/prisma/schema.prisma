generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ROLES.md — admin: to'liq huquq; engineer: operatsion (agregat/statik
// parametr); viewer: faqat o'qish.
enum Role {
  ADMIN
  ENGINEER
  VIEWER
}

// SENDMAIL.md — yangi ro'yxatdan o'tgan foydalanuvchi PENDING holatda
// yaratiladi, admin tasdiqlagach APPROVED (login ochiladi), rad etsa REJECTED.
enum AccountStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                  Int                  @id @default(autoincrement())
  fullName            String?
  orgName             String?
  phone               String?              @default("+998")
  email               String               @unique
  password            String? // Google orqali kirganlarda parol yo'q
  role                Role                 @default(VIEWER)
  status              AccountStatus        @default(PENDING)
  provider            String               @default("local") // "local" | "google"
  googleId            String?              @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  orders              Order[]              @relation("OrderAuthors")
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_reset_tokens")
}

model Ges {
  id          Int         @id @default(autoincrement())
  name        String
  power       String?
  region      String?
  status      String?
  repair      String?
  latitude    Float?
  longitude   Float?
  isAktive    Boolean     @default(false)
  isPublished Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  aggregates  Aggregate[]

  @@map("ges_list")
}

model Aggregate {
  id               Int                    @id @default(autoincrement())
  hydroTurbine     Json?
  hydroGenerator   Json?
  transformer      Json?
  gesId            Int
  ges              Ges                    @relation(fields: [gesId], references: [id], onDelete: Cascade)
  state            String                 @default("running")
  isPublished      Boolean                @default(false)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  fuzzyAssessments FuzzyAssessment[]
  staticParams     EquipmentStaticParam[]
  sensorReadings   SensorReading[]

  @@map("aggregates")
}

// GES asosiy jihozi turi — FUZZY.md §1 (Gidroturbina, Gidrogenerator, Transformator).
// GES — uchala jihozni birlashtiruvchi yakuniy FIS bosqichi uchun (FUZZY.md §3.D).
enum EquipmentType {
  TURBINE
  GENERATOR
  TRANSFORMER
  GES
}

// Har bir FIS bosqichi (Fgt, f1..f6, Fgg, Ftr, GES) natijasi shu yerda saqlanadi.
// FUZZY.md §7 "fuzzy_assessments" jadvaliga mos.
model FuzzyAssessment {
  id              Int           @id @default(autoincrement())
  aggregateId     Int
  aggregate       Aggregate     @relation(fields: [aggregateId], references: [id], onDelete: Cascade)
  equipmentType   EquipmentType
  assessmentType  String // masalan: "Fgt", "f1", "f2", "F_gg", "GES"
  healthScore     Float // 0-100
  healthStatus    String // "Juda yomon" | "Yomon" | "O'rtacha" | "Yaxshi" | "A'lo"
  inputParameters Json?
  firedRules      Json?
  assessedAt      DateTime      @default(now())

  @@index([aggregateId, equipmentType, assessmentType])
  @@map("fuzzy_assessments")
}

// Statik parametrlar (nominal qiymatlar, ta'mirdan keyin o'zgaradigan
// qarshiliklar va h.k.) — FUZZY.md §7 "equipment_metadata" jadvaliga mos.
// Bir (aggregateId, equipmentType, paramName) juftligi uchun bitta joriy
// qiymat saqlanadi (yangilanganda ustiga yoziladi — tarix kerak emas).
model EquipmentStaticParam {
  id            Int           @id @default(autoincrement())
  aggregateId   Int
  aggregate     Aggregate     @relation(fields: [aggregateId], references: [id], onDelete: Cascade)
  equipmentType EquipmentType
  paramName     String
  paramValue    Float
  unit          String?
  paramType     String        @default("nominal") // "nominal" | "warning_high" | ...
  updatedAt     DateTime      @updatedAt

  @@unique([aggregateId, equipmentType, paramName])
  @@map("equipment_static_params")
}

// Dinamik (sensordan keladigan) parametrlar — FUZZY.md §7 "sensor_data"
// jadvaliga mos, TimescaleDB hypertable sifatida ishlatiladi (vaqt
// seriyali samaradorlik uchun, CLAUDE.md #5.1). Hypertable talabi bo'yicha
// vaqt ustuni (`recordedAt`) barcha unique/PK cheklovlarga kirishi shart —
// shu sabab alohida autoincrement `id` yo'q, kompozit kalit ishlatiladi.
model SensorReading {
  aggregateId   Int
  aggregate     Aggregate     @relation(fields: [aggregateId], references: [id], onDelete: Cascade)
  equipmentType EquipmentType
  paramName     String
  value         Float
  unit          String?
  recordedAt    DateTime      @default(now())

  @@id([aggregateId, equipmentType, paramName, recordedAt])
  @@map("sensor_readings")
}

// .claude/rules/fuzzy-logic.md #2: "Barcha IF-THEN qoidalari fuzzy_rules
// jadvalda saqlanishi kerak (qattiq kod emas). Faqat asosiy (default) 10 ta
// qoida kodda bo'lishi mumkin." Bitta o'zgaruvchining a'zolik funksiyasini
// (5 sinf) qurish uchun yetarli ma'lumot: turi + 5 ta markaz.
//
// kind: "deviation" (nominaldan og'ish, masalan Aylanish tezligi — nominal
// qiymat equipment_static_params'dan `variable` nomi bo'yicha olinadi),
// "direct" (xom qiymat, masalan Tebranish), "score" (boshqa FIS chiqishi,
// 0-100 domen, masalan f3/f4 — f5'ga kirish sifatida).
model FuzzyVariableDefinition {
  id             Int      @id @default(autoincrement())
  assessmentType String // "Fgt", "f1", "f2", "f3", "f4", "f6", "GES"
  variable       String // masalan "aylanishTezligi"
  kind           String // "deviation" | "direct" | "score"
  centers        Json // [n,n,n,n,n] o'sish tartibida
  ascendingOrder Json? // faqat "direct" uchun; null = sukut (kichik qiymat yaxshi)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([assessmentType, variable])
  @@map("fuzzy_variable_definitions")
}

model FuzzyRuleDefinition {
  id             Int      @id @default(autoincrement())
  assessmentType String
  antecedents    Json // { o'zgaruvchi: chiqishSinfi, ... }
  outputClass    String
  weight         Float    @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([assessmentType])
  @@map("fuzzy_rule_definitions")
}

model HydroGenerator {
  id        Int      @id @default(autoincrement())
  name      String?
  power     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hydro_generators")
}

model HydroTurbine {
  id        Int      @id @default(autoincrement())
  name      String?
  power     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hydro_turbines")
}

model Transformer {
  id        Int      @id @default(autoincrement())
  name      String?
  power     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("transformers")
}

model Order {
  id          Int      @id @default(autoincrement())
  message     String?
  type        String?
  isOrdered   String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authors     User[]   @relation("OrderAuthors")

  @@map("orders")
}
